DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (auto-switches based on DEBUG in settings)
DATABASE_URL=sqlite:///db.sqlite3
# Production: DATABASE_URL=postgres://user:pass@localhost:5432/route_optimizer

# Cache (auto-switches based on DEBUG in settings)
# Production: REDIS_URL=redis://localhost:6379/1

# OSRM API
OSRM_BASE_URL=http://router.project-osrm.org
OSRM_ROUTE_ENDPOINT=/route/v1/driving/

# Vehicle Configuration
VEHICLE_RANGE_MILES=500
FUEL_EFFICIENCY_MPG=10
TANK_CAPACITY_GALLONS=50

# Optimization
ROUTE_CORRIDOR_WIDTH_MILES=25
CACHE_TTL_SECONDS=86400
